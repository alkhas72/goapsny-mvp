# Server-side / CI (never expose service role to the browser)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<legacy-jwt-secret>

# Public PWA client (Vite build — safe for browser bundle)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Public map engine: leaflet (default) | maplibre (vector parity gate)
# VITE_MAP_ENGINE=maplibre

# Isolated test project gate (scripts only — never commit values)
TEST_SUPABASE_URL=https://<test-project-ref>.supabase.co
TEST_SUPABASE_ANON_KEY=<test-anon-key>
TEST_SUPABASE_SERVICE_ROLE_KEY=<test-service-role-key>
TEST_SUPABASE_PROJECT_REF=<test-project-ref>

TELEGRAM_BOT_TOKEN=<goapsny-bot-token>

OPENAI_API_KEY=<openai-api-key>
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_ESTIMATED_COST_USD=0.0020
AI_MONTHLY_BUDGET_USD=50

EXPORT_JOB_SECRET=<random-long-secret>
